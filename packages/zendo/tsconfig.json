{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": true
  },
  // astro/ and remark/ depend on the consumer's generated astro:* virtual modules
  // and are typechecked inside the consuming Astro app, not standalone.
  "include": ["src/config.ts", "src/sources/**/*", "src/transformers/**/*", "src/cli/**/*"]
}
