---
import type { CollectionEntry } from "astro:content";
import { getIngredientNameMap, prettifyId } from "src/lib/recipes/ingredients";
import { formatQuantityWithUnit } from "src/lib/recipes/format";

export interface Props {
  recipe: CollectionEntry<"recipes">;
}

const { recipe } = Astro.props;
const groups = recipe.data.ingredient_groups;
const serves = recipe.data.serves;

const nameMap = await getIngredientNameMap();
---

{
  groups.length > 0 && (
    <div data-controller={serves ? "servings" : undefined} data-servings-base-value={serves}>
      <h2 id="ingredients">Ingredients</h2>

      {serves && (
        <div class="not-prose flex items-center gap-2 font-sans text-sm text-stone-500">
          <span>Servings:</span>
          <button
            type="button"
            aria-label="Decrease servings"
            data-action="servings#decrement"
            class="flex h-6 w-6 items-center justify-center rounded border border-stone-300 text-stone-600 hover:bg-stone-100"
          >
            &minus;
          </button>
          <span data-servings-target="count" class="min-w-4 text-center font-semibold text-stone-700">
            {serves}
          </span>
          <button
            type="button"
            aria-label="Increase servings"
            data-action="servings#increment"
            class="flex h-6 w-6 items-center justify-center rounded border border-stone-300 text-stone-600 hover:bg-stone-100"
          >
            +
          </button>
        </div>
      )}

      {groups.map((group) => (
        <>
          {group.group && <p>For the {group.group.toLowerCase()}:</p>}
          <ul>
            {group.ingredients.map((item) => (
              <li>
                {item.id ? (
                  <>
                    {nameMap.get(item.id.id) ?? prettifyId(item.id.id)}
                    {(item.quantity !== undefined || item.note) && (
                      <>
                        {" ("}
                        {item.quantity !== undefined && (
                          <span data-servings-target="quantity" data-quantity={item.quantity} data-unit={item.unit}>
                            {formatQuantityWithUnit(item.quantity, item.unit)}
                          </span>
                        )}
                        {item.quantity !== undefined && item.note && ", "}
                        {item.note}
                        {")"}
                      </>
                    )}
                  </>
                ) : (
                  item.note
                )}
              </li>
            ))}
          </ul>
        </>
      ))}
    </div>
  )
}
