{
  "name": "alessandro.codes",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.18.0"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "prettier --check . && eslint . && astro check",
    "format": "prettier --write . && eslint --fix .",
    "zendo": "npx tsx node_modules/zendo/src/cli/bin.ts",
    "zendo:fetch": "npx tsx node_modules/zendo/src/cli/bin.ts fetch",
    "zendo:reindex": "npx tsx node_modules/zendo/src/cli/bin.ts reindex",
    "zendo:build": "npx tsx node_modules/zendo/src/cli/bin.ts build",
    "zendo:update": "npm run zendo:build && git add src/data/index.json src/content && git commit -m 'Update content' && git push",
    "tsc": "tsc"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/vercel": "^11.0.0",
    "@hotwired/stimulus": "^3.2.2",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "astro-icon": "^1.1.5",
    "cheerio": "^1.2.0",
    "date-fns": "^4.4.0",
    "gray-matter": "^4.0.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "zendo": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-regular": "^1.2.4",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/fs-extra": "^11.0.4",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "prettier": "^3.9.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.62.0"
  }
}
